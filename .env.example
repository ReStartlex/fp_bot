# Скопируй этот файл в .env и заполни своими значениями.
# .env в git НЕ попадает (см. .gitignore).

ENABLE_REAL_ACTIONS=false
SYNC_INTERVAL_SECONDS=30
# Поиск новых лотов на FunPay (для пуша алерта «появился лот без маппинга»)
NEW_LOTS_NOTIFY_ENABLED=true
NEW_LOTS_CHECK_INTERVAL_SECONDS=180
NEW_LOTS_SUGGEST_ENABLED=true
NEW_LOTS_SUGGEST_MAX=3
NEW_LOTS_SUGGEST_MIN_SCORE=20
TIMEZONE=Europe/Moscow
NS_USE_PLAYGROUND=false

NS_BASE_URL=https://api.ns.gifts
NS_USER_ID=
NS_LOGIN=
NS_PASSWORD=
NS_API_SECRET=
NS_TOTP_SECRET=
NS_LOW_BALANCE_THRESHOLD=20

FUNPAY_GOLDEN_KEY=
FUNPAY_PHPSESSID=
FUNPAY_USER_ID=
FUNPAY_CHAT_LANGUAGE=ru

# Наценка по умолчанию (можно переопределить на конкретный маппинг).
# Подбирай так, чтобы лот оставался конкурентным относительно соседних
# на FunPay (обычно 5% для конкурентных популярных позиций).
MARKUP_PERCENT=5
FUNPAY_CURRENCY=RUB
# auto = берём курс с cbr-xml-daily.ru; manual = используем USD_RUB_RATE как есть
USD_RUB_RATE_MODE=auto
USD_RUB_RATE=90
# Премия к биржевому курсу: разница между ЦБ-курсом и реальной ценой
# покупки USD (Bybit и пр.). 3.0 = курс ЦБ * 1.03. Применяется только в auto.
USD_RUB_PREMIUM_PERCENT=3.0
PRICE_UPDATE_THRESHOLD_PERCENT=2
FUNPAY_STOCK_CAP=100
# Safety guardrails для sync.
SYNC_MIN_MARGIN_PERCENT=1
SYNC_MAX_PRICE_CHANGE_PERCENT=50
SYNC_RESERVE_PENDING_ORDERS=true
# Справочная комиссия FunPay для оценки цены клиента в /calc.
# На наш sync не влияет — мы пишем цену продавца, FunPay сам добавит комиссию.
FUNPAY_COMMISSION_PERCENT=12.5
# Потеря при выводе денег с FunPay. Учитывается только в расчётах прибыли.
FUNPAY_WITHDRAWAL_FEE_PERCENT=3.0

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=true
# Использовать прокси для api.telegram.org? Если сервер сам имеет доступ — false.
TELEGRAM_USE_PROXY=false
TELEGRAM_PROXY_TYPE=socks5
TELEGRAM_PROXY_HOST=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_USERNAME=
TELEGRAM_PROXY_PASSWORD=

# === Phase 1: TG-shop (отдельный бот для покупателей) ===
# Создаётся отдельным ботом через @BotFather. Полностью независим от
# owner-бота выше (там — команды владельца, тут — каталог/корзина/оплата).
#
# Безопасно держать SHOP_ENABLED=false пока не получил SHOP_TELEGRAM_BOT_TOKEN.
# Когда будешь готов:
#   1. @BotFather → /newbot → даст токен и @username
#   2. SHOP_TELEGRAM_BOT_TOKEN=<токен>
#   3. SHOP_ENABLED=true
#   4. рестарт funpay-ns-bot.service
SHOP_ENABLED=false
SHOP_TELEGRAM_BOT_TOKEN=
# Markup для shop-цен. Дешевле FunPay-площадки (~13% накрутка платформы),
# но удерживает комфортную маржу (vs ~2% net на FunPay после комиссий).
# 8 = +8% к курсу NS×FX.
# Можно переопределить через owner-бота (runtime): /shop_markup N (TODO Спринт 2).
SHOP_MARKUP_PERCENT=8
# 1% от каждой покупки реферала идёт на внутренний баланс пригласившего.
# Балансом можно частично/полностью оплачивать заказы в этом боте.
SHOP_REFERRAL_PERCENT=1
# Как часто обновлять каталог из NS.get_stock(). 90с — баланс между свежестью
# (out-of-stock виден быстро) и нагрузкой на NS API (1 запрос/90с).
SHOP_CATALOG_REFRESH_SECONDS=90

# === Web API для будущего сайта ===
# По умолчанию отдельный API выключен, чтобы не влиять на текущий bot service.
WEB_API_ENABLED=false
WEB_API_HOST=127.0.0.1
WEB_API_PORT=8080
# Обязателен для защищённых /api/* endpoints. Перед сайтом задай длинный случайный токен.
WEB_API_TOKEN=

LOG_LEVEL=INFO
LOG_DIR=logs

FUNPAY_UPDATE_RATE_LIMIT_PER_SECOND=1

# === FunPay 429 (rate-limit от сервера FunPay) ===
# Когда FunPay возвращает HTTP 429 (часто во время массового sync_stock
# или при пиковой нагрузке самого FunPay), мы делаем терпеливый
# exponential backoff с уважением заголовка Retry-After.
#
# Применяется ко ВСЕМ обращениям FunPayAdminClient: GET /lots/offerEdit,
# GET /chat/, POST /lots/offerSave (save_lot), POST /runner/ (send_message).
#
# FUNPAY_429_MAX_RETRIES=4 → суммарно до 5 попыток.
# Реальные паузы: 1s, 2s, 4s, 8s (capped до MAX_BACKOFF) — около 15с
# суммарно. Этого достаточно, чтобы временный 429 рассосался.
# Если FunPay прислал Retry-After (число секунд), используем его вместо
# exponential (но не больше MAX_BACKOFF, чтобы не зависнуть).
FUNPAY_429_MAX_RETRIES=4
FUNPAY_429_BASE_BACKOFF_SECONDS=1.0
FUNPAY_429_MAX_BACKOFF_SECONDS=30.0

# === FunPay 5xx (transient gateway: 502 Bad Gateway / 503 Service
# Unavailable / 504 Gateway Timeout) ===
# Применяется только к GET-запросам (get_lot_fields, /chat/, ...) и к
# сетевым ошибкам (connection refused, etc.). POST 5xx (save_lot,
# send_message) НЕ ретраится автоматически: для send_message это риск
# двойной отправки сообщения.
#
# 5xx у FunPay обычно transient и рассасывается за 1-5 секунд, поэтому
# 2 retries (всего 3 попытки) достаточно: суммарно ~3 секунды задержки.
# Если FunPay лежит дольше — лучше пропустить лот, sync вернётся через
# 30 секунд в следующем цикле.
#
# base/max backoff берутся из FUNPAY_429_* (общие).
# 500 НЕ ретраим (это application bug у FunPay, повтор бесполезен).
FUNPAY_5XX_MAX_RETRIES=2

# === Глобальный rate-limit на исходящие FunPay-запросы ===
# Предотвращает 429 ДО его возникновения. Применяется одновременно к
# GET (get_lot_fields, /chat/, ...) и POST (save_lot, send_message)
# — общий счётчик, потому что FunPay считает общий RPS.
#
# Видимая проблема в проде (23.05.2026): на одном offerEdit URL мы
# получали 429 → 429 → 200, на 4 разных URL подряд в первые секунды
# после старта. Это значит FunPay активно ограничивает наш burst.
#
# max_concurrent: сколько HTTP-запросов могут идти одновременно.
#   4 — консервативно (asyncio thread pool обычно 6-10, оставляем
#   запас на SQLite, обработчики и т.п.).
# min_interval_seconds: минимальная пауза между ЛЮБЫМИ двумя
#   запросами. 0.1 = max 10 RPS даже при concurrent=1.
FUNPAY_RATE_MAX_CONCURRENT=4
FUNPAY_RATE_MIN_INTERVAL_SECONDS=0.1

# === Diff-based sync_stock cache ===
# Главная оптимизация для снижения нагрузки на FunPay:
# sync_stock каждые 30 сек проверяет N лотов, но в проде стабильно
# меняется только 1-2 лота на цикл. 46 GET-запросов идут «впустую»
# и провоцируют 429.
#
# С diff-cache: после успешного save_lot запоминаем (price, stock, active).
# В следующем цикле, если NS-target совпадает с cache и cache свежий
# (моложе TTL) — пропускаем FunPay-запрос целиком.
# Раз в TTL делаем «полный» цикл — на случай если кто-то правил
# цены на FunPay вручную (наш cache мог разъехаться).
#
# Ожидаемый эффект: 47 GET -> 2-3 GET за цикл, 429 пропадает как класс.
# Откатить можно без передеплоя: SYNC_STOCK_DIFF_CACHE_ENABLED=false + restart.
SYNC_STOCK_DIFF_CACHE_ENABLED=true
# 120 сек = 2 минуты. Прежний дефолт 300с давал слишком длинное окно
# рассогласования (если save_lot падал во время кризиса или цена правилась
# вручную через FunPay UI). 120с сохраняет ×4-5 экономии rate-limit'а,
# но окно неконсистентности уже короткое.
SYNC_STOCK_DIFF_CACHE_TTL_SECONDS=120

NS_RETRY_ATTEMPTS=3
NS_RETRY_DELAY_SECONDS=5
NS_ORDER_POLL_INTERVAL_SECONDS=5
NS_ORDER_TIMEOUT_SECONDS=600
ORDER_RECONCILE_ENABLED=true
ORDER_RECONCILE_INTERVAL_SECONDS=120
ORDER_RECONCILE_STALE_AFTER_SECONDS=60
ORDER_RECONCILE_MAX_PER_RUN=10

# Жёсткий лимит на полный цикл received → delivered (секунды, 300..1800).
# Если бот не успел доставить за это время:
#  - заказ переходит в manual_hold (не failed: его можно ретраить из Telegram);
#  - FunPay-лот аварийно выключается, чтобы новые заказы не попадали в ту же ловушку;
#  - в Telegram прилетает алерт с кнопками "Retry / Выдано вручную / Детали".
# Если оператор уже выдал товар вручную и нажал "Выдано вручную", автоматический
# Retry больше не отправит дубль (status=delivered блокирует и обычный pipeline,
# и force-retry).
# 600 = 10 минут (по умолчанию). Уменьшать ниже 420 не советую: NS иногда отвечает
# 5-7 минут на медленных карточках.
ORDER_DELIVERY_HARD_TIMEOUT_SECONDS=600

# === Чат с покупателями ===
# Автоматически здороваться, когда покупатель пишет в чат
CHAT_AUTOGREETING_ENABLED=true
# Сколько часов не повторять приветствие в том же чате
CHAT_GREETING_COOLDOWN_HOURS=24
# Слова-триггеры для вызова владельца (через запятую). Регистр не важен.
CHAT_HELP_TRIGGERS=!help,!помощь,!support,!оператор,!sos,!админ
# 0 = отвечать и уведомлять на каждое "!помощь" без антиспама.
CHAT_HELP_COOLDOWN_SECONDS=0
# Окно после покупки, в течение которого !помощь не останавливает автовыдачу.
# Если заказ не выдан после окна, он перейдет в manual_hold.
CHAT_HELP_AUTO_DELIVERY_GRACE_SECONDS=420
# Если продавец вручную написал в чат после оплаты, блокировать позднюю автовыдачу.
ORDER_MANUAL_INTERVENTION_GUARD_SECONDS=7200
# Сколько верхних активных чатов дополнительно проверять каждый poll.
# Нужно для повторных одинаковых сообщений: "!помощь" -> "!помощь".
FUNPAY_ACTIVE_CHATS_POLL_LIMIT=5
# Размер LRU-дедупа watcher'а. Прежний 1024 на активном аккаунте мог
# переполниться и тогда старое сообщение, выпавшее из deque, повторно
# срабатывало после очередного poll'а. 4096 запасом покрывает сутки
# активной торговли (~30 чатов × ~10 сообщений × 12 polls/min).
FUNPAY_WATCHER_DEDUP_CACHE_SIZE=4096

# === Order discovery poll (3-й канал доставки заказов) ===
# listen-loop FunPayAPI выключен (FUNPAY_LISTEN_ENABLED=false) и в любом
# случае нестабилен. Системные сообщения «оплачен заказ #...» из poll-loop
# в ChatHandler НЕ создают Order — они помечают только ChatState.
# Из-за этого часть заказов выпадает: NS-покупка не запускается,
# владелец не получает «✅ Заказ выполнен».
#
# Этот воркер каждые N секунд тянет свежий список paid-заказов
# (account.get_sells(state="paid")) и для каждого, которого нет в БД,
# поднимает FunPayOrderEvent и зовёт process_funpay_order. См.
# src/orders/discovery.py.
FUNPAY_ORDER_DISCOVERY_ENABLED=true
FUNPAY_ORDER_DISCOVERY_INTERVAL_SECONDS=60
# Защита от NS-burst, если вдруг скопилось много пропущенных заказов:
# больше N за один прогон не обрабатываем, остальное подберёт след. тик.
FUNPAY_ORDER_DISCOVERY_MAX_PER_RUN=10

# === NS health watchdog ===
# Периодический «жив ли NS?» с алертами в Telegram. Если NS лежит,
# владелец узнаёт об этом быстро (а не через 6-часовой heartbeat) и
# может вручную выключить все лоты одной кнопкой «🔴 Выключить все лоты»
# в меню бота. После восстановления приходит «✅ NS жив».
NS_HEALTH_WATCHDOG_ENABLED=true
NS_HEALTH_WATCHDOG_INTERVAL_SECONDS=90
# Сколько подряд провалов до первого алерта. 3 при интервале 90с =
# ~4.5 минуты — даёт NS шанс быть просто медленным, не флудит на
# одно «моргание сети».
NS_HEALTH_WATCHDOG_ALERT_AFTER_FAILURES=3
NS_HEALTH_WATCHDOG_CHECK_TIMEOUT_SECONDS=5
# Рабочие часы (по часовому поясу TIMEZONE)
WORK_HOURS_START=12
WORK_HOURS_END=23
# Как тебя называть в шаблонах ("Алексей" -> "Я (Алексей) отвечу в течение часа")
SELLER_DISPLAY_NAME=продавец
